# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# PostgreSQL database connection string
# Local example: postgresql://postgres:password@localhost:5432/rhyzzle
# Supabase example: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/rhyzzle"

# Next.js app URL (used for generating share links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Session secret for signing guest session cookies
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

